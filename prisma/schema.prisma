generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SessionReport {
  id                   String   @id @default(cuid())
  questionnaireAnswers String   // JSON — risposte complete del questionario
  riskCategory         String   // "unacceptable" | "high" | "limited" | "minimal"
  riskScore            Int      // 1-100
  classificationJson   String   // JSON — classificazione completa da Claude
  reportMarkdown       String   // Report generato in Markdown
  pdfGenerated         Boolean  @default(false)
  leadId               String?
  lead                 Lead?    @relation(fields: [leadId], references: [id])
  createdAt            DateTime @default(now())
  viewedAt             DateTime?
  expiresAt            DateTime
}

model Lead {
  id               String   @id @default(cuid())
  email            String?
  name             String?
  source           String   // "questionnaire" | "contact" | "cta"
  hasBookedCall    Boolean  @default(false)
  notes            String?
  reports          SessionReport[]
  createdAt        DateTime @default(now())
  contactedAt      DateTime?
}
